<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="24dp">

    <!-- 中間內容 -->
    <LinearLayout
        android:id="@+id/centerSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/my_photo"
            android:scaleType="centerCrop"
            android:contentDescription="個人照片" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Eric"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Student / Basketball Player"
            android:textSize="18sp"
            android:textColor="#2E7D32" />
    </LinearLayout>

    <!-- 底部聯絡資訊 -->
    <LinearLayout
        android:id="@+id/contactSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0975893473"
            android:textSize="18sp"
            android:textColor="@android:color/holo_blue_dark"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvSocial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kao_905"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kaotzuchi0905@gmail.com"
            android:textSize="18sp"
            android:textColor="@android:color/holo_blue_dark"
            android:padding="8dp" />
    </LinearLayout>

</LinearLayout>